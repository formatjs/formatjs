  "project": [
    "packages/**/*.{ts,tsx}",
    "tools/**/*.ts",
    "docs/**/*.{ts,tsx}",
    "benchmarks/**/*.ts",
  ],
  "testFilePatterns": [
    "**/*.test.*",
    "**/benchmark/**/*",
    "**/conformance-tests/**/*",
    "**/integration-tests/**/*",
    "**/tests/**/*",
  ],
  "ignore": [
    "packages/**/locale-data/**",
    "packages/react-intl/example-sandboxes/**",
    "**/*.d.ts",
    "packages/**/integration-tests/fixtures/**",
    "packages/**/tests/fixtures/**",
    "packages/cli/integration-tests/extract/typescript/err.tsx",
    "docs/src/vite-env.d.ts",
  ],
  // Root package.json#imports is not visible from nested package scopes.
  "aliases": {
    "#packages/*": "./packages/*",
  },
  "unresolvedImports": {
    "mode": "report",
    "ignore": ["@formatjs_generated/**", "./package.json"],
  },
  "ignoreExportsUsedInFile": true,
}

+def _link_validator_packages(rctx):
+    version = rctx.attr.validator_ts_version or _DEFAULT_VALIDATOR_TYPESCRIPT_VERSION
+    if not version.startswith("6."):
+        fail("validator_ts_version must select a TypeScript 6 release, got {}".format(version))
+    integrity = rctx.attr.validator_ts_integrity or TOOL_VERSIONS.get(version)
+    if not integrity:
+        fail("""validator TypeScript version {} is not mirrored in rules_ts.
+            If this is a real version, specify 'validator_ts_integrity'.""".format(version))
+
+    # @typescript/typescript6 is a proxy to a floating typescript@^6 dependency.
+    # Fetch the exact classic compiler payload and expose it under the compatibility
+    # package name so repository resolution remains hermetic.
+    _download_package(
+        rctx,
+        "https://registry.npmjs.org/typescript/-/typescript-{}.tgz".format(version),
+        "validator_package",
+        integrity,
+    )
+
+    targets = """npm_package_internal(
+    name = "npm_typescript6",
+    src = "validator_package/package",
+    package = "@typescript/typescript6",
+    version = "{version}",
+)
+
+npm_link_package(
+    name = "node_modules/@typescript/typescript6",
+    src = ":npm_typescript6",
+    visibility = ["//visibility:public"],
+)
+""".format(version = version)
+    labels = ['    ":node_modules/@typescript/typescript6",\n']
+    return labels, [targets]
+

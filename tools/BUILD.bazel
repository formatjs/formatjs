load("@aspect_bazel_lib//lib:copy_to_bin.bzl", "copy_to_bin")
load("@bazel_skylib//:bzl_library.bzl", "bzl_library")
load("//tools:index.bzl", "ts_binary")

exports_files([
    "supported-locales-gen.ts",
])

copy_to_bin(
    name = "vitest_config_mjs",
    srcs = ["vitest.config.mjs"],
    visibility = ["//visibility:public"],
)

copy_to_bin(
    name = "check-package-json",
    srcs = ["check-package-json.ts"],
    visibility = ["//visibility:public"],
)

ts_binary(
    name = "generate-supported-locales",
    data = [
        "//:node_modules/fs-extra",
        "//:node_modules/minimist",
    ],
    entry_point = "generate-supported-locales.ts",
    visibility = ["//visibility:public"],
)

bzl_library(
    name = "index",
    srcs = ["index.bzl"],
    visibility = ["//visibility:public"],
    deps = [
        ":oxc_transpiler",
        ":tsconfig",
        "@aspect_bazel_lib//lib:copy_to_bin",
        "@aspect_bazel_lib//lib:write_source_files",
        "@aspect_rules_js//js:defs",
        "@aspect_rules_ts//ts:defs",
        "@npm//:@typescript/native-preview/package_json",
    ],
)

bzl_library(
    name = "vitest",
    srcs = ["vitest.bzl"],
    visibility = ["//visibility:public"],
    deps = [
        ":tsconfig",
        "@aspect_bazel_lib//lib:write_source_files",
        "@aspect_rules_ts//ts:defs",
        "@npm//:@typescript/native-preview/package_json",
        "@npm//:vitest/package_json",
    ],
)

bzl_library(
    name = "oxc_transpiler",
    srcs = ["oxc_transpiler.bzl"],
    visibility = ["//visibility:public"],
)

bzl_library(
    name = "tsconfig",
    srcs = ["tsconfig.bzl"],
    visibility = ["//visibility:public"],
)

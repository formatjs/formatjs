TEST_LOCALE_DATA = ["tests/locale-data/%s.json" % locale for locale in TEST_LOCALES]

TEST_DEPS = [
    "//packages/ecma262-abstract",
    "//packages/ecma402-abstract",
    "//packages/ecma402-abstract/NumberFormat",
    "//packages/ecma402-abstract/types",
    "//:node_modules/@formatjs/intl-localematcher",
    "//:node_modules/@formatjs/bigdecimal",
    "//:node_modules/@formatjs/intl-pluralrules",
    "//:node_modules/@formatjs/intl-getcanonicallocales",
    "//:node_modules/@formatjs/intl-locale",
    "//:node_modules/@formatjs_generated/cldr.number",
    "//:node_modules/@formatjs_generated/cldr.supported-locales",
    "//:node_modules/@types/node",
]

ENTRY_POINTS = [
    "index.ts",
    "polyfill.ts",
    "polyfill-force.ts",
    "should-polyfill.ts",
]

formatjs_library(
    name = "intl-numberformat",
    srcs = [
        "core.ts",
        "get_internal_slots.ts",
        "index.ts",
        "polyfill.ts",
        "polyfill-force.ts",
        "should-polyfill.ts",
        "to_locale_string.ts",
        "types.ts",
    ],
    entry_points = ENTRY_POINTS,
    extra_npm_srcs = [
        ":locale-data",
        "polyfill.iife.js",
    ],
    types = True,
    visibility = ["//visibility:public"],
    deps = [
        "//:node_modules/@formatjs/bigdecimal",
        "//:node_modules/@formatjs/intl-localematcher",
        "//:node_modules/@formatjs_generated/cldr.number",
        "//:node_modules/@formatjs_generated/cldr.supported-locales",
        "//packages/ecma262-abstract",
        "//packages/ecma402-abstract",
        "//packages/ecma402-abstract/NumberFormat",
        "//packages/ecma402-abstract/types",
    ],
)

UNIT_TEST_LOCALES = [
    "en",
    "en-GB",
    "da",
    "de",
    "es",
    "fr",
    "id",
    "it",
    "ja",
    "ko",
    "ms",
    "nb",
    "nl",
    "pl",
    "pt",
    "ru",
    "sv",
    "th",
    "tr",
    "uk",
    "zh",
    "en-BS",
]

LOCALE_TEST_TYPES = [
    "currency",
    "decimal",
    "unit",
    "percent",
]

[genrule(
    name = "%s_test_update_snapshots_gen" % type,
    srcs = ["//packages/intl-numberformat/scripts:update_snapshots.sh"],
    outs = ["%s_test_update_snapshots.sh" % type],
    cmd = """
    cat $< > $@\n
    """ + "\n".join(["echo 'bazel run //%s:%s_%s_test_update_snapshots' >> $@ " % (
        package_name(),
        type,
        locale,
    ) for locale in UNIT_TEST_LOCALES]),
) for type in LOCALE_TEST_TYPES]

[sh_binary(
    name = "%s_test_update_snapshots" % type,
    srcs = ["%s_test_update_snapshots.sh" % type],
    data = ["//packages/intl-numberformat/scripts:update_snapshots.sh"],
    deps = ["@bazel_tools//tools/bash/runfiles"],
) for type in LOCALE_TEST_TYPES]

[
    [ts_run_binary(
        name = "%s_%s_test_gen" % (type, locale),
        srcs = [
            "//:node_modules/fs-extra",
            "//:node_modules/minimist",
        ],
        outs = ["tests/%s/%s.generated.test.ts" % (type, locale)],
        args = [
            "--locale",
            locale,
            "--type",
            type,
            "--out",
            "$(rootpath tests/%s/%s.generated.test.ts)" % (type, locale),
        ],
        tool = "//packages/intl-numberformat/scripts:generate-locale-test",
    ) for locale in UNIT_TEST_LOCALES]
    for type in LOCALE_TEST_TYPES
]

vitest(
    name = "misc_tests",
    size = "large",
    srcs = glob([
               "tests/*.test.ts",
           ]) + [":srcs"] +
           TEST_LOCALE_DATA,
    data = ["//:package.json"],
    no_copy_to_bin = ["//:package.json"],
    tsconfig = packages_tsconfig(ESNEXT_TSCONFIG),
    deps = TEST_DEPS,
)

[
    vitest(
        name = "%s_tests" % type,
        size = "large",
        srcs = [
            "tests/%s/%s.generated.test.ts" % (type, locale)
            for locale in UNIT_TEST_LOCALES
        ] + [
            ":srcs",
            "tests/%s/%sTest.ts" % (type, type),
        ] + TEST_LOCALE_DATA,
        data = ["//:package.json"],
        no_copy_to_bin = ["//:package.json"],
        tsconfig = packages_tsconfig(ESNEXT_TSCONFIG),
        deps = TEST_DEPS,
    )
    for type in LOCALE_TEST_TYPES
]

# CLDR

cldr_locale_list(
    name = "locales",
    cldr_package = "cldr-numbers-full",
    data = [
        "//:node_modules/cldr-numbers-full",
    ],
    file_glob = "*/numbers.json",
)

CLDR_RAW_FILES = ["cldr-raw/%s.json" % locale for locale in ALL_LOCALES]

ts_run_binary(
    name = "cldr-raw",
    srcs = [
        "//:node_modules/@types/lodash-es",
        "//:node_modules/cldr-core",
        "//:node_modules/cldr-numbers-full",
        "//:node_modules/cldr-units-full",
        "//:node_modules/fast-glob",
        "//:node_modules/fs-extra",
        "//:node_modules/json-stable-stringify",
        "//:node_modules/lodash-es",
        "//:node_modules/minimist",
        "//packages/ecma262-abstract",
        "//packages/ecma402-abstract",
        "//packages/ecma402-abstract/NumberFormat",
        "//packages/ecma402-abstract/types",
    ],
    outs = CLDR_RAW_FILES,
    args = [
        "--outDir",
        "cldr-raw",
    ],
    chdir = package_name(),
    tool = "//packages/intl-numberformat/scripts:cldr-raw",
    visibility = [
        "//packages/intl:__subpackages__",
        "//packages/react-intl:__subpackages__",
    ],
)

ts_run_binary(
    name = "locale-data",
    srcs = CLDR_RAW_FILES + [
        "//:node_modules/fs-extra",
        "//:node_modules/minimist",
    ],
    outs = ["locale-data/%s.js" % locale for locale in ALL_LOCALES] + ["locale-data/%s.d.ts" % locale for locale in ALL_LOCALES],
    args = [
        "--cldrFile %s" % f
        for f in CLDR_RAW_FILES
    ] + [
        "--outDir",
        "locale-data",
    ],
    chdir = package_name(),
    tool = "//packages/intl-numberformat/scripts:cldr",
    visibility = ["//visibility:public"],
)

[genrule(
    name = "tests-locale-data-%s" % locale,
    srcs = ["cldr-raw/%s.json" % locale],
    outs = ["tests/locale-data/%s.json" % locale],
    cmd = "cp $< $@",
) for locale in TEST_LOCALES]

TEST262_LOCALES = [
    "ar",
    "de",
    "en",
    "ja",
    "ko",
    "th",
    "zh",
    "zh-Hant",
    "zh-Hans",
]

ts_run_binary(
    name = "test262-main-gen",
    srcs = [
        ":cldr-raw",
        "//:node_modules/fs-extra",
        "//:node_modules/minimist",
    ],
    outs = ["test262-main.ts"],
    args = [
        "--cldrFile %s/cldr-raw/%s.json" % (
            package_name(),
            f,
        )
        for f in TEST262_LOCALES
    ] + [
        "--out",
        "$(rootpath test262-main.ts)",
    ],
    tool = "//packages/intl-numberformat/scripts:test262-main-gen",
)


LOCALE_TEST_TYPES = [
    "currency",
    "decimal",
    "unit",
    "percent",
]

[genrule(
    name = "%s_test_update_snapshots_gen" % type,
    srcs = ["//packages/intl-numberformat/scripts:update_snapshots.sh"],
    outs = ["%s_test_update_snapshots.sh" % type],
    cmd = """
    cat $< > $@\n
    """ + "\n".join(["echo 'bazel run //%s:%s_%s_test_update_snapshots' >> $@ " % (
        package_name(),
        type,
        locale,
    ) for locale in UNIT_TEST_LOCALES]),
) for type in LOCALE_TEST_TYPES]

[sh_binary(
    name = "%s_test_update_snapshots" % type,
    srcs = ["%s_test_update_snapshots.sh" % type],
    data = ["//packages/intl-numberformat/scripts:update_snapshots.sh"],
    deps = ["@bazel_tools//tools/bash/runfiles"],
) for type in LOCALE_TEST_TYPES]

[
    [generate_src_file(
        name = "%s_%s_test" % (type, locale),
        src = "tests/%s/%s.generated.test.ts" % (type, locale),
        args = [
            "--locale",
            locale,
            "--type",
            type,
        ],
        tool = ":generate-locale-test",
    ) for locale in UNIT_TEST_LOCALES]
    for type in LOCALE_TEST_TYPES
]

multirun(
    name = "tests_gen",
    testonly = True,
    commands = [
        ":%s_%s_test" % (type, locale)
        for type in LOCALE_TEST_TYPES
        for locale in UNIT_TEST_LOCALES
    ],
)

[
    [
        ts_project(
            # Type-check only (tsgo, no emit)
            name = "%s_tests_typecheck" % type,
            testonly = True,
            srcs = [
                "tests/%s/%s.generated.test.ts" % (type, locale)
                for locale in UNIT_TEST_LOCALES
            ] + [
                ":srcs",
                "tests/%s/%sTest.ts" % (type, type),
            ] + TEST_LOCALE_DATA,
            declaration = True,
            no_emit = True,
            resolve_json_module = True,
            transpiler = tsgo_bin.tsgo,
            tsconfig = TEST_TSCONFIG,
            deps = TEST_DEPS + [d for d in VITEST_DEPS if d not in TEST_DEPS],
        ),
        vitest_runner(
            name = "%s_tests" % type,
            size = "large",
            srcs = [
                "tests/%s/%s.generated.test.ts" % (type, locale)
                for locale in UNIT_TEST_LOCALES
            ] + [
                ":srcs",
                "tests/%s/%sTest.ts" % (type, type),
            ] + TEST_LOCALE_DATA,
            deps = TEST_DEPS,
        ),
    ]
    for type in LOCALE_TEST_TYPES
]


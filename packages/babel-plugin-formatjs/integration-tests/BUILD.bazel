load("//tools:formatjs_lib.bzl", "formatjs_ts_project")

# gazelle:js disabled

load("@npm//:@typescript/native-preview/package_json.bzl", tsgo_bin = "bin")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools:vitest.bzl", "TEST_TSCONFIG", "VITEST_DEPS", "vitest_runner")

npm_link_all_packages()

formatjs_ts_project(
    # Type-check only (tsgo, no emit)
    name = "vue_integration_test_typecheck",
    testonly = True,
    srcs = glob(["vue/fixtures/*"]) + [
        "vue/integration.test.ts",
    ],
    declaration = True,
    no_emit = True,
    resolve_json_module = True,
    tags = ["no-typecheck-test"],
    transpiler = tsgo_bin.tsgo,
    tsconfig = TEST_TSCONFIG,
    deps = [
        ":node_modules/babel-plugin-formatjs",
        "//:node_modules/@babel/types",
        "//:node_modules/@types/webpack",
        "//:node_modules/babel-loader",
        "//:node_modules/typescript",
        "//:node_modules/vue",
        "//:node_modules/vue-loader",
        "//:node_modules/webpack",
    ] + VITEST_DEPS,
)

vitest_runner(
    name = "vue_integration_test",
    srcs = glob(["vue/fixtures/*"]) + [
        "vue/integration.test.ts",
    ],
    test_timeout = "20000",
    deps = [
        ":node_modules/babel-plugin-formatjs",
        "//:node_modules/@babel/types",
        "//:node_modules/@types/webpack",
        "//:node_modules/babel-loader",
        "//:node_modules/typescript",
        "//:node_modules/vue",
        "//:node_modules/vue-loader",
        "//:node_modules/webpack",
    ],
)

load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools:package_json.bzl", "generate_package_json")
load("//tools:vitest.bzl", "vitest")

generate_package_json(
    package_name = "integration-tests",
    private = True,
    deps = [
        "//:node_modules/babel-plugin-formatjs",
    ],
)

# Manually-managed integration test: a vitest() with glob'd fixtures.
# Auto-generated formatjs_test would race with the existing rule.
# gazelle:ts_enabled false

npm_link_all_packages()

vitest(
    name = "vue_integration_test",
    srcs = glob(["vue/fixtures/*"]) + [
        "vue/integration.test.ts",
    ],
    test_timeout = "20000",
    deps = [
        "//:node_modules/@babel/types",
        "//:node_modules/@types/webpack",
        "//:node_modules/babel-loader",
        "//:node_modules/babel-plugin-formatjs",
        "//:node_modules/typescript",
        "//:node_modules/vue",
        "//:node_modules/vue-loader",
        "//:node_modules/webpack",
    ],
)

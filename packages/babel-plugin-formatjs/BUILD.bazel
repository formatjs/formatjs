load("//tools:compile.bzl", "formatjs_library")
load("//tools:test.bzl", "formatjs_test")

formatjs_library(
    name = "babel-plugin-formatjs",
    package_name = "babel-plugin-formatjs",
    srcs = [
        "global.d.ts",
        "index.ts",
        "types.ts",
        "utils.ts",
        "visitors/call-expression.ts",
        "visitors/jsx-opening-element.ts",
    ],
    author = "Long Ho <holevietlong@gmail.com>",
    bugs = "https://github.com/formatjs/formatjs/issues",
    description = "Extracts string messages for translation from modules that use formatjs.",
    homepage = "https://github.com/formatjs/formatjs#readme",
    keywords = [
        "babel-plugin",
        "react-intl",
    ],
    license = "MIT",
    main = "index.js",
    npm_package_name = "babel-plugin-formatjs",
    package_types = "index.d.ts",
    repository = "formatjs/formatjs.git",
    type = "module",
    version = "11.3.15",  # x-release-please-version
    visibility = ["//visibility:public"],
    exports = {
        ".": "./index.js",
    },
    deps = [
        "//:node_modules/@babel/core",
        "//:node_modules/@babel/helper-plugin-utils",
        "//:node_modules/@babel/plugin-syntax-jsx",
        "//:node_modules/@babel/traverse",

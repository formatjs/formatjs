        "//:node_modules/@formatjs/icu-messageformat-parser",
        "//:node_modules/@formatjs/ts-transformer",
        "//:node_modules/@types/babel__core",
        "//:node_modules/@types/babel__helper-plugin-utils",
        "//:node_modules/@types/babel__traverse",
    ],
)


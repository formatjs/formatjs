{
  "compilerOptions": {
    "composite": true,
    "paths": {
      "#packages/*": ["../../packages/*"],
      "@formatjs_generated/*": ["../../node_modules/@formatjs_generated/*"]
    }
  },
  "exclude": [
    "./DateTimeFormat/**/*",
    "./DisplayNames/**/*",
    "./DurationFormat/**/*",
    "./NumberFormat/**/*",
    "./PluralRules/**/*",
    "./RelativeTimeFormat/**/*",
    "./scripts/**/*",
    "./types/**/*"
  ],
  "extends": "../../tsconfig.json",
  "references": [
    {
      "path": "../ecma262-abstract/tsconfig.json"
    }
  ]
}

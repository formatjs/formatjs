    "composite": true,
    "paths": {
      "#packages/*": ["../../packages/*"]
    }
  },
  "exclude": [
    "./DisplayNames/**/*",
    "./NumberFormat/**/*",
    "./scripts/**/*",
    "./types/**/*"
  ],
  "extends": "../../tsconfig.json",

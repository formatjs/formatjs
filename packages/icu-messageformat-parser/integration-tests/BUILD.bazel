load("@rules_rs//rs:rust_test.bzl", "rust_test")
load("//tools:index.bzl", "generate_src_file")
load("//tools:package_json.bzl", "generate_package_json")
load("//tools:vitest.bzl", "vitest")

generate_package_json(
    package_name = "integration-tests",
    private = True,
    deps = [
        "//:node_modules/@formatjs/icu-messageformat-parser",
    ],
)

# run-parser.ts is the entry_point of an existing js_run_binary; an
# auto-generated formatjs_library would race with it on srcs/deps.
# gazelle:ts_enabled false

TEST_CASES = glob(["test_cases/*"])

# Generate a file listing all test case filenames
genrule(
    name = "generate_test_list",
    srcs = TEST_CASES,
    outs = ["test_list.txt"],
    cmd = "echo '$(SRCS)' | tr ' ' '\\n' | xargs -n1 basename > $@",
)

# Single Rust test that runs all integration test cases
rust_test(
    name = "integration_tests",
    size = "small",
    srcs = ["integration_tests.rs"],
    data = TEST_CASES + [":test_list.txt"],
    deps = [
        "//crates/icu_messageformat_parser",
        "@crates//:pretty_assertions",
        "@crates//:serde_json",
        "@rules_rust//rust/runfiles",
    ],
)


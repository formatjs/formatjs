[generate_src_file(
    name = "gen_parser_test_%s" % f.split("/")[-1],
    src = f,
    args = [
        "--input %s/%s" % (
            package_name(),
            f,
        ),
    ],
    data = [
        "//:node_modules/@formatjs/icu-messageformat-parser",
        "//:node_modules/lodash-es",
        f,
    ],
    entry_point = "run-parser.ts",
) for f in TEST_CASES]

load("@aspect_rules_js//js:defs.bzl", "js_library", "js_test")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools:index.bzl", "generate_tsconfig_json")
load("//tools:package_json.bzl", "generate_package_json")
load("//tools:test.bzl", "formatjs_test")
load("//tools:vitest.bzl", "vitest")

# gazelle:exclude react_consumer_smoke_test.ts

js_library(
    name = "react_consumer_smoke_test_lib",
    srcs = ["react_consumer_smoke_test.ts"],
    visibility = ["//visibility:public"],
)

generate_package_json(
    package_name = "integration-tests",
    private = True,
    deps = [
        "//:node_modules/react-intl",
    ],
)

npm_link_all_packages()

generate_tsconfig_json(
    name = "tsconfig_json",
    local_only = True,
    tsconfig = {
        "extends": "../../../tsconfig.json",
        "compilerOptions": {
            "target": "es6",
            "types": [
                "jest",
                "node",
                "@testing-library/jest-dom",
            ],
            "sourceMap": True,
        },
    },
)

TEST_DEPS = [
    "//:node_modules/react-intl",
    "//:node_modules/@testing-library/jest-dom",
    "//:node_modules/@testing-library/react",
    "//:node_modules/@types/aria-query",
    "//:node_modules/@types/node",
    "//:node_modules/@types/react-dom",
    "//:node_modules/@types/react",
    "//:node_modules/react-dom",
    "//:node_modules/react",
]

vitest(
    name = "test",
    srcs = glob(
        ["*.ts*"],
        exclude = ["react_consumer_smoke_test.ts"],
    ),
    dom = True,
    deps = TEST_DEPS,
)

REACT_CONSUMER_SMOKE_DEPS = [
    "//:node_modules/@formatjs/icu-messageformat-parser",
    "//:node_modules/@formatjs/intl",
    "//:node_modules/intl-messageformat",
    "//:node_modules/react",
    "//:node_modules/react-dom",
    "//packages/react-intl:pkg",
]

js_test(
    name = "react_consumer_smoke_test",
    size = "small",
    args = ["$(rootpath //packages/react-intl:pkg)"],
    data = REACT_CONSUMER_SMOKE_DEPS,
    entry_point = ":react_consumer_smoke_test_lib",
    node_options = ["--experimental-transform-types"],
)

formatjs_test(
    name = "integration-tests_test",
    srcs = ["format.test.tsx"],
    deps = [
        "//:node_modules/@testing-library/jest-dom",
        "//:node_modules/@testing-library/react",
        "//:node_modules/@types/react",
        "//:node_modules/react",
        "//:node_modules/react-intl",
        "//:node_modules/vitest",
    ],
)

load("@aspect_bazel_lib//lib:copy_to_directory.bzl", "copy_to_directory")
load("@npm//:tsd/package_json.bzl", tsd_bin = "bin")

# tsd type-tests use a custom copy_to_directory pipeline; an auto-generated
# formatjs_library for the .test-d.ts file would conflict.
# gazelle:ts_enabled false

PACKAGE_NAME = "react-intl"

copy_to_directory(
    name = "global_type_overrides_test_files",
    srcs = [
        "global_type_overrides.test-d.ts",
        "//packages/react-intl:pkg",
        "//packages/react-intl:tsconfig_json_generated",
    ],
    out = "global_type_overrides_test_files",
    replace_prefixes = {
        "packages/react-intl/pkg": "",
        "packages/react-intl/tsconfig_json.generated.json": "tsconfig.json",
        "global_type_overrides.test-d.ts": "tests/global_type_overrides.test-d.ts",
    },
)

tsd_bin.tsd_test(
    name = "global_type_overrides_test",
    size = "small",
    args = [
        "--files",
        "tests/global_type_overrides.test-d.ts",
    ],
    chdir = "packages/%s/tests/tsd/global_type_overrides_test_files" % PACKAGE_NAME,
    data = [
        ":global_type_overrides_test_files",
        "//:node_modules/@formatjs/icu-messageformat-parser",
        "//:node_modules/@formatjs/intl",
        "//:node_modules/@types/react",
        "//:node_modules/intl-messageformat",
        "//:node_modules/react",
        "//:node_modules/tsd",
        "//packages/ecma402-abstract",
        "//packages/ecma402-abstract/types",
    ],
)

load("@aspect_bazel_lib//lib:copy_file.bzl", "copy_file")
load("@aspect_bazel_lib//lib:copy_to_bin.bzl", "copy_to_bin")
load("@aspect_bazel_lib//lib:write_source_files.bzl", "write_source_files")
load("@aspect_rules_js//npm:defs.bzl", "npm_package")
load("@aspect_rules_ts//ts:defs.bzl", "ts_config", "ts_project")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools:index.bzl", "generate_ide_tsconfig_json", "generate_src_file", "package_json_test", "ts_compile")
load("//tools:vitest.bzl", "vitest")

npm_link_all_packages(name = "node_modules")

exports_files([
    "package.json",
    # This comes from https://www.six-group.com/dam/download/financial-information/data-center/iso-currrency/lists/list-one.xml
    # We check this in bc they don't version this file
    "data/list-one.xml",
])

PACKAGE_NAME = "utils"

npm_package(
    name = "pkg",
    srcs = [
        "LICENSE.md",
        "README.md",
        "package.json",
        ":dist",
    ],
    package = "@formatjs/%s" % PACKAGE_NAME,
    visibility = ["//visibility:public"],
)

SRCS = glob([
    "src/**/*",
    "*.ts",
])

SRC_DEPS = [
    ":node_modules/@formatjs/fast-memoize",
]

ts_compile(
    name = "dist",
    srcs = [":srcs"],
    deps = SRC_DEPS,
)

# Generate tsconfig.json with correct extends path
generate_ide_tsconfig_json()

package_json_test(
    name = "package_json_test",
    deps = SRC_DEPS,
)

vitest(
    name = "unit_test",
    srcs = SRCS + glob([
        "tests/*.ts*",
    ]),
    deps = SRC_DEPS,
)

generate_src_file(
    name = "default-currency",
    src = "src/defaultCurrencyData.generated.ts",
    data = [
        "//:node_modules/cldr-core",
    ],
    entry_point = "tools/extract-default-currency.ts",
    tags = ["cldr"],
)

generate_src_file(
    name = "default-locale",
    src = "src/defaultLocaleData.generated.ts",
    data = [
        "//:node_modules/cldr-core",
    ],
    entry_point = "tools/extract-default-locale.ts",
    tags = ["cldr"],
)

copy_file(
    name = "iso-4217",
    src = "data/list-one.xml",
    out = "iso4217.xml",
)

generate_src_file(
    name = "currency-minor-units",
    src = "src/currencyMinorUnits.generated.ts",
    args = [
        "--input",
        "$(rootpath :iso4217.xml)",
    ],
    data = [
        ":iso4217.xml",
        ":node_modules/fast-xml-parser",
    ],
    entry_point = "tools/extract-minor-currency-units.ts",
)

copy_to_bin(
    name = "srcs",
    srcs = SRCS,
)

ts_project(
    name = "utils",
    srcs = [
        "index.ts",
        "src/countryCodes.ts",
        "src/currencyMinorUnits.generated.ts",
        "src/defaultCurrency.ts",
        "src/defaultCurrencyData.generated.ts",
        "src/defaultLocale.ts",
        "src/defaultLocaleData.generated.ts",
        "src/defaultTimezone.ts",
        "src/iso3166Alpha3CountryCodes.ts",
        "src/iso4217.ts",
        "tools/extract-default-currency.ts",
        "tools/extract-default-locale.ts",
        "tools/extract-minor-currency-units.ts",
    ],
    declaration = True,
    isolated_typecheck = True,
    preserve_jsx = False,
    resolve_json_module = True,
    tsconfig = ":tsconfig",
    deps = [
        ":node_modules/@formatjs/fast-memoize",
        ":node_modules/fast-xml-parser",
        "//:node_modules/@types/fs-extra",
        "//:node_modules/@types/minimist",
        "//:node_modules/@types/node",
        "//:node_modules/cldr-core",
        "//:node_modules/fs-extra",
        "//:node_modules/minimist",
    ],
)

ts_project(
    name = "utils_tests",
    testonly = True,
    srcs = [
        "tests/countryCodes.test.ts",
        "tests/currencyMinorUnits.test.ts",
        "tests/defaultCurrency.test.ts",
        "tests/defaultLocale.test.ts",
        "tests/defaultTimezone.test.ts",
    ],
    declaration = True,
    isolated_typecheck = True,
    preserve_jsx = False,
    resolve_json_module = True,
    tsconfig = ":tsconfig",
    deps = [
        ":utils",
        "//:node_modules/vitest",
    ],
)

ts_config(
    name = "tsconfig",
    src = "tsconfig.json",
    visibility = [":__subpackages__"],
)

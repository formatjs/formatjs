load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools:package_json.bzl", "generate_package_json")
load("//tools:vitest.bzl", "vitest")

generate_package_json(
    package_name = "unplugin-integration-tests",
    private = True,
    deps = [
        "//:node_modules/@formatjs/unplugin",
    ],
)

# Manually-managed integration test: a single vitest() with glob'd srcs.
# Auto-generated formatjs_library + formatjs_test would race with the
# vitest rule and require a checked-in tsconfig.json this dir doesn't have.
# gazelle:ts_enabled false

npm_link_all_packages()

vitest(
    name = "integration_test",
    srcs = glob(["*.ts"]),
    fixtures = glob(["fixtures/*"]),
    deps = [
        "//:node_modules/@formatjs/unplugin",
        "//:node_modules/@rspack/core",
        "//:node_modules/@types/react",
        "//:node_modules/esbuild",
        "//:node_modules/react",
        "//:node_modules/rollup",
        "//:node_modules/webpack",
    ],
)

vitest(
    name = "extract_vue_integration_test",
    srcs = glob(
        ["extract-vue/*.test.ts"],
    ),
    fixtures = glob(
        ["extract-vue/**/*"],
        exclude = ["extract-vue/*.test.ts"],
    ),
    deps = [
        ":node_modules/@formatjs/cli",
        "//:node_modules/@babel/types",
        "//:node_modules/@vue/compiler-core",
        "//:node_modules/fast-glob",
        "//:node_modules/vue",
    ],
)

vitest(
    name = "extract_glimmer_integration_test",
    srcs = glob(
        ["extract-glimmer/*.test.ts"],
    ),
    fixtures = glob(
        ["extract-glimmer/**/*"],
        exclude = ["extract-glimmer/*.test.ts"],
    ),
    deps = [
        ":node_modules/@formatjs/cli",
        "//:node_modules/@babel/types",
        "//:node_modules/fast-glob",
    ] + GLIMMER_HBS_DEPS,
)

vitest(
    name = "compile_integration_test",
    srcs = [
        "formatter.js",
        "rust-binary-utils.ts",
        ":node_modules/@formatjs/cli",
        ":rust_cli_copy",
    ] + glob(
        ["compile/**/*"],
    ),
    data = [
        "//crates/formatjs_cli",
    ],
    deps = ["//:node_modules/@bazel/runfiles"],
)

vitest(
    name = "verify_integration_test",
    srcs = [
        "rust-binary-utils.ts",
        ":rust_cli_copy",
    ] + glob(
        ["verify/*.test.ts"],
    ),
    data = [
        "//crates/formatjs_cli",
    ],
    fixtures = glob(
        ["verify/**/*"],
        exclude = [
            "verify/*.test.ts",
            "verify/__snapshots__/*",
        ],
    ),
    deps = [
        ":node_modules/@formatjs/cli",
        "//:node_modules/@bazel/runfiles",
    ],
)

vitest(
    name = "conformance_test",
    srcs = [
        "rust-binary-utils.ts",
        ":node_modules/@formatjs/cli",
        ":rust_cli_copy",
    ] + glob(
        ["conformance-tests/*.test.ts"],
    ),
    data = [
        "//crates/formatjs_cli",
    ],
    fixtures = glob(
        ["conformance-tests/test_cases/*.txt"],
    ),
    deps = [
        "//:node_modules/@bazel/runfiles",
        "//:node_modules/@types/fs-extra",
        "//:node_modules/fs-extra",
    ],
)

ts_project(
    name = "integration-tests",
    srcs = [
        "extract/duplicated/file1.tsx",
        "extract/duplicated/file2.tsx",
        "extract/inFile/file1.tsx",
        "extract/inFile/file2.tsx",
        "extract/issue-6009/Test.tsx",
        "extract/nonDuplicated/file1.tsx",
        "extract/nonDuplicated/file2.tsx",
        "extract/optionalChaining/actual.tsx",
        "extract/taggedTemplates/actual.tsx",
        "extract/throwsFlag/all-valid.tsx",
        "extract/throwsFlag/mixed-valid-invalid.tsx",
        "extract/typescript/actual.ignore.tsx",
        "extract/typescript/actual.tsx",
        "extract/typescript/err.tsx",
        "extract/typescript/importMeta.mts",
        "extract/typescript/non-static.tsx",
        "extract/typescript/pragma.tsx",
        "extract/typescript/ts47.tsx",
        "package.json",
        "rust-binary-utils.ts",
    ],
    declaration = True,
    isolated_typecheck = True,
    preserve_jsx = False,
    resolve_json_module = True,
    tsconfig = "//:tsconfig",
    deps = [
        "//:node_modules/@bazel/runfiles",
        "//:node_modules/@types/node",
        "//:node_modules/@types/react",
        "//:node_modules/react",
    ],
)

ts_project(
    name = "integration-tests_tests",
    testonly = True,
    srcs = [
        "compile/integration.test.ts",
        "compile_folder/integration.test.ts",
        "conformance-tests/conformance.test.ts",
        "extract-glimmer/integration.test.ts",
        "extract-vue/integration.test.ts",
        "verify/integration.test.ts",
    ],
    declaration = True,
    isolated_typecheck = True,
    preserve_jsx = False,
    resolve_json_module = True,
    tsconfig = "//:tsconfig",
    deps = [
        ":integration-tests",
        "//:node_modules/@types/fs-extra",
        "//:node_modules/@types/node",
        "//:node_modules/fast-glob",
        "//:node_modules/fs-extra",
        "//:node_modules/vitest",
    ],
)

ts_project(
    # Type-check only (tsgo, no emit)
    name = "compile_integration_test_typecheck",
    testonly = True,
    srcs = [
        "formatter.js",
        "rust-binary-utils.ts",
        ":node_modules/@formatjs/cli",
        ":rust_cli_copy",
    ] + glob(
        ["compile/**/*"],
    ),
    declaration = True,
    no_emit = True,
    resolve_json_module = True,
    transpiler = tsgo_bin.tsgo,
    tsconfig = TEST_TSCONFIG,
    deps = ["//:node_modules/@bazel/runfiles"] + VITEST_DEPS,
)

vitest_runner(
    name = "compile_integration_test",
    srcs = [
        "formatter.js",
        "rust-binary-utils.ts",
        ":node_modules/@formatjs/cli",
        ":rust_cli_copy",
    ] + glob(
        ["compile/**/*"],
    ),
    data = [
        "//crates/formatjs_cli",
    ],
    deps = ["//:node_modules/@bazel/runfiles"],
)

ts_project(
    # Type-check only (tsgo, no emit)
    name = "verify_integration_test_typecheck",
    testonly = True,
    srcs = [
        "rust-binary-utils.ts",
        ":rust_cli_copy",
    ] + glob(
        ["verify/*.test.ts"],
    ),
    declaration = True,
    no_emit = True,
    resolve_json_module = True,
    transpiler = tsgo_bin.tsgo,
    tsconfig = TEST_TSCONFIG,
    deps = [
        ":node_modules/@formatjs/cli",
        "//:node_modules/@bazel/runfiles",
    ] + VITEST_DEPS,
)

vitest_runner(
    name = "verify_integration_test",
    srcs = [
        "rust-binary-utils.ts",
        ":rust_cli_copy",
    ] + glob(
        ["verify/*.test.ts"],
    ),
    data = [
        "//crates/formatjs_cli",
    ],
    fixtures = glob(
        ["verify/**/*"],
        exclude = [
            "verify/*.test.ts",
            "verify/__snapshots__/*",
        ],
    ),
    deps = [
        ":node_modules/@formatjs/cli",
        "//:node_modules/@bazel/runfiles",
    ],
)

ts_project(
    # Type-check only (tsgo, no emit)
    name = "conformance_test_typecheck",
    testonly = True,
    srcs = [
        "rust-binary-utils.ts",
        ":node_modules/@formatjs/cli",
        ":rust_cli_copy",
    ] + glob(
        ["conformance-tests/*.test.ts"],
    ),
    declaration = True,
    no_emit = True,
    resolve_json_module = True,
    transpiler = tsgo_bin.tsgo,
    tsconfig = TEST_TSCONFIG,
    deps = [
        "//:node_modules/@bazel/runfiles",
        "//:node_modules/@types/fs-extra",
        "//:node_modules/fs-extra",
    ] + VITEST_DEPS,

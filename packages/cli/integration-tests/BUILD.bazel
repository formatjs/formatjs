# gazelle:js disabled

load("@aspect_bazel_lib//lib:copy_file.bzl", "copy_file")
load("@aspect_rules_ts//ts:defs.bzl", "ts_project")
load("@npm//:@typescript/native-preview/package_json.bzl", tsgo_bin = "bin")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools:vitest.bzl", "TEST_TSCONFIG", "VITEST_DEPS", "vitest_runner")

npm_link_all_packages()

# Copy Rust CLI binary to integration tests directory so js_run_binary can find it
copy_file(
    name = "rust_cli_copy",
    src = "//crates/formatjs_cli",
    out = "formatjs_cli",
    visibility = ["//visibility:private"],
)

GLIMMER_HBS_DEPS = [
    "//:node_modules/@glimmer/syntax",
    "//:node_modules/content-tag",
]

# Export fixtures for use by Rust CLI integration tests
filegroup(
    name = "compile_fixtures",
    srcs = glob(["compile/**/*"]),
    visibility = ["//visibility:public"],
)

filegroup(
    name = "extract_fixtures",
    srcs = glob(
        ["extract/**/*"],
        exclude = [
            "extract/**/*.test.ts",
            "extract/__snapshots__/*",
        ],
    ),
    visibility = ["//visibility:public"],
)

filegroup(
    name = "verify_fixtures",
    srcs = glob(
        ["verify/**/*"],
        exclude = [
            "verify/*.test.ts",
            "verify/__snapshots__/*",
        ],
    ),
    visibility = ["//visibility:public"],
)

ts_project(
    # Type-check only (tsgo, no emit)
    name = "compile_folder_integration_test_typecheck",
    testonly = True,
    srcs = glob(
        ["compile_folder/*.test.ts"],
    ),
    declaration = True,
    no_emit = True,
    resolve_json_module = True,
    transpiler = tsgo_bin.tsgo,
    tsconfig = TEST_TSCONFIG,
    deps = [
        ":node_modules/@formatjs/cli",
        "//:node_modules/@types/fs-extra",
        "//:node_modules/fast-glob",
        "//:node_modules/fs-extra",
    ] + VITEST_DEPS,
)

vitest_runner(
    name = "compile_folder_integration_test",
    srcs = glob(
        ["compile_folder/*.test.ts"],
    ),
    fixtures = glob(
        ["compile_folder/**/*"],
        exclude = ["compile_folder/*.test.ts"],
    ),
    deps = [
        ":node_modules/@formatjs/cli",
        "//:node_modules/@types/fs-extra",
        "//:node_modules/fast-glob",
        "//:node_modules/fs-extra",
    ],
)


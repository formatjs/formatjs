ts_project(
    # Type-check only (tsgo, no emit)
    name = "extract_vue_integration_test_typecheck",
    testonly = True,
    srcs = glob(
        ["extract-vue/*.test.ts"],
    ),
    declaration = True,
    no_emit = True,
    resolve_json_module = True,
    transpiler = tsgo_bin.tsgo,
    tsconfig = TEST_TSCONFIG,
    deps = [
        ":node_modules/@formatjs/cli",
        "//:node_modules/@babel/types",
        "//:node_modules/@vue/compiler-core",
        "//:node_modules/fast-glob",
        "//:node_modules/vue",
    ] + VITEST_DEPS,
)

vitest_runner(
    name = "extract_vue_integration_test",
    srcs = glob(
        ["extract-vue/*.test.ts"],
    ),
    fixtures = glob(
        ["extract-vue/**/*"],
        exclude = ["extract-vue/*.test.ts"],
    ),
    deps = [
        ":node_modules/@formatjs/cli",
        "//:node_modules/@babel/types",
        "//:node_modules/@vue/compiler-core",
        "//:node_modules/fast-glob",
        "//:node_modules/vue",
    ],
)

ts_project(
    # Type-check only (tsgo, no emit)
    name = "extract_glimmer_integration_test_typecheck",
    testonly = True,
    srcs = glob(
        ["extract-glimmer/*.test.ts"],
    ),
    declaration = True,
    no_emit = True,
    resolve_json_module = True,
    transpiler = tsgo_bin.tsgo,
    tsconfig = TEST_TSCONFIG,
    deps = [
        ":node_modules/@formatjs/cli",
        "//:node_modules/@babel/types",
        "//:node_modules/fast-glob",
    ] + GLIMMER_HBS_DEPS + VITEST_DEPS,
)

vitest_runner(
    name = "extract_glimmer_integration_test",
    srcs = glob(
        ["extract-glimmer/*.test.ts"],
    ),
    fixtures = glob(
        ["extract-glimmer/**/*"],
        exclude = ["extract-glimmer/*.test.ts"],
    ),
    deps = [
        ":node_modules/@formatjs/cli",
        "//:node_modules/@babel/types",
        "//:node_modules/fast-glob",
